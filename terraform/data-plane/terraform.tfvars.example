# Copy this file to terraform.tfvars and fill in the values.

aws_region   = "us-east-1"
project_name = "firework-example"

# Root domain for DNS records and the wildcard ACM certificate.
# A Route53 hosted zone for this domain must already exist in your account.
domain_name = "example.com"

# Availability zones — update if deploying to a different region.
# availability_zones = ["us-east-1a", "us-east-1c"]

# Auto-wire control-plane outputs from local state (recommended).
# If your control-plane state is elsewhere, update control_plane_state_path or
# set use_control_plane_remote_state = false and provide manual overrides below.
use_control_plane_remote_state = true
control_plane_state_path       = "../control-plane/terraform.tfstate"

# Optional manual overrides (normally auto-wired from control-plane outputs):
# s3_configs_bucket_id  = "firework-example-configs-xxxx"
# s3_configs_bucket_arn = "arn:aws:s3:::firework-example-configs-xxxx"
# s3_configs_prefix     = "cp/v1/"
# registry_url          = "https://registry.example.com:9443"
# registry_server_name  = "registry.example.com"

# Preferred: step-ca bootstrap (AWS IID, no registry bootstrap token on nodes).
# Usually auto-wired from control-plane outputs; uncomment only to override.
# step_ca_url                = "https://pki.example.internal:9000"
# step_ca_root_ca_secret_arn = "arn:aws:secretsmanager:us-east-1:123456789012:secret:firework-step-ca-root-ca-xxxxx"
# step_ca_provisioner        = "aws-iid"
# step_ca_subject_suffix     = ".node.firework.internal"
# step_ca_renew_expires_in   = "8h"

# Legacy fallback (registry enrollment token path).
# Usually auto-wired from control-plane outputs; uncomment only to override.
# registry_client_ca_secret_arn       = "arn:aws:secretsmanager:us-east-1:123456789012:secret:firework-node-client-ca-xxxxx"
# registry_bootstrap_token_secret_arn = "arn:aws:secretsmanager:us-east-1:123456789012:secret:firework-bootstrap-token-xxxxx"

# Pre-existing images bucket managed by CI (not created by Terraform).
# Create once: aws s3 mb s3://<name> --region us-east-1
s3_images_bucket_id  = "your-images-bucket-name"
s3_images_bucket_arn = "arn:aws:s3:::your-images-bucket-name"

# AMI built by Packer (see packer/ directory).
# Run: cd packer && packer build firework-node.pkr.hcl
# Then paste the AMI ID here.
node_ami_id   = "ami-0123456789abcdef0"
node_key_name = "my-key-pair"

# Instance type must support bare-metal / KVM for Firecracker.
# c6g.metal = ARM Graviton2, 64 vCPUs, 128 GB RAM.
node_instance_type = "c6g.metal"

# Number of Firecracker nodes.
node_count = 2

# Guest networking (defaults match the agent's built-in defaults).
# vm_subnet  = "172.16.0.0/24"
# vm_gateway = "172.16.0.1"
