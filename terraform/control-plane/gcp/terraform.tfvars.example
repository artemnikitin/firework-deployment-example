gcp_project        = "my-gcp-project"
gcp_region         = "us-central1"
dns_zone_name      = "firework-gcp"
events_domain      = "events.gcp.example.com"
# Optional: set to create a DNS A record for registry.<base_domain> and emit
# a DNS-based registry_url/registry_server_name. When auto_create_demo_secrets = true,
# the auto-generated registry TLS cert will use a DNS SAN for registry.<base_domain>.
# base_domain = "gcp.example.com"
state_bucket_name  = "firework-cp-state-my-gcp-project"
controlplane_image = "ghcr.io/artemnikitin/firework-controlplane:v1.2.3"
git_repo_url       = "https://github.com/OWNER/firework-gitops-example.git"
target_branch      = "main"
# config_dir selects an optional GitOps subdirectory as the enricher input root.
# Leave empty (the default) to consume the repository root.
config_dir = ""

# --- Secret Manager secret IDs ---
# Only the webhook secret must be pre-created. All TLS certs, the enrollment CA,
# and the bootstrap token are auto-generated by Terraform when
# auto_create_demo_secrets = true (the default).
webhook_secret_id = "firework-webhook-secret"

# To bring your own certs/keys instead of auto-generating them, set:
# auto_create_demo_secrets   = false
# bootstrap_token_secret_id  = "my-bootstrap-token"
# events_tls_cert_secret_id  = "my-events-tls-cert"
# events_tls_key_secret_id   = "my-events-tls-key"
# registry_tls_cert_secret_id  = "my-registry-tls-cert"
# registry_tls_key_secret_id   = "my-registry-tls-key"
# enrollment_ca_cert_secret_id = "my-enrollment-ca-cert"
# enrollment_ca_key_secret_id  = "my-enrollment-ca-key"

# Optional: set to a Secret Manager secret ID containing a GitHub token
# for private GitOps repositories.
# github_token_secret_id = "firework-github-token"
