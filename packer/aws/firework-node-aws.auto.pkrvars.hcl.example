# Copy this file to firework-node-aws.auto.pkrvars.hcl and adjust as needed.

aws_region          = "us-east-1"
instance_type       = "t4g.large"   # any ARM64 instance works — metal is only needed at runtime
firecracker_version = "1.12.0"
traefik_version     = "3.3.4"

# Required when the account has no default VPC — set both or neither.
# The subnet must be a public subnet so Packer can SSH into the builder instance.
# vpc_id    = "vpc-0123456789abcdef0"
# subnet_id = "subnet-0123456789abcdef0"

# Optional: extend AWS waiter timeouts (default: 15s * 120 attempts = 30 min).
# Raise max_attempts if using a metal builder instance, which terminates slowly.
# aws_poll_delay_seconds = 15
# aws_poll_max_attempts  = 240   # ~60 min, useful for metal builders

# Option A: Upload a locally built agent binary (ARM64).
# Build with: cd firework && GOARCH=arm64 make build
# firework_agent_path = "../firework/bin/firework-agent"

# Option B: Download from GitHub releases (default).
firework_agent_version = "latest"
# github_token = "..."  # Required for private repos
